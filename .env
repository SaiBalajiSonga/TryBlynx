# ═══════════════════════════════════════════════
# TryBlynx — Environment Configuration
# ═══════════════════════════════════════════════

# ── Server Configuration ───────────────────────────
PORT=8080
ENV=development

# ── PostgreSQL ─────────────────────────────────────
POSTGRES_USER=tryblynx
POSTGRES_PASSWORD=tryblynx
POSTGRES_DB=tryblynx
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable

# Preserved DSN for Go app inside Docker network
DATABASE_URL=postgres://tryblynx:tryblynx@postgres:5432/tryblynx?sslmode=disable

# ── Redis (Cache & Matchmaking Pub/Sub) ───────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Preserved URL for Go app
REDIS_URL=redis://redis:6379/0

# ── Security & Authentication ─────────────────────
JWT_SECRET=super_secret_eccentric_key_change_this_in_production
JWT_EXPIRATION_HOURS=24

# ── WebRTC / Coturn Signaling ─────────────────────
TURN_SERVER_AUTH_SECRET=coturn_secret_pass
TURN_SERVER_REALM=tryblynx.com

# ── Stripe (Preserved) ─────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── Database Pool (Go pgxpool) (Preserved) ─────
DB_MAX_CONNS=100
DB_MIN_CONNS=10
