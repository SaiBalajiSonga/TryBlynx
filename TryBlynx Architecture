```go
func StripeWebhookHandler(w http.ResponseWriter, r *http.Request) {
    // 1. Read raw body (max 64KB)
    payload, _ := io.ReadAll(io.LimitReader(r.Body, 65536))

    // 2. Cryptographically verify signature
    event, err := webhook.ConstructEvent(
        payload,
        r.Header.Get("Stripe-Signature"),
        os.Getenv("STRIPE_WEBHOOK_SECRET"),
    )
    // 3. Reject if invalid
    if err != nil {
        w.WriteHeader(http.StatusBadRequest)
        return
    }

    // 4. Handle checkout.session.completed
    if event.Type == "checkout.session.completed" {
        // Extract customer email / metadata user_id
        // UPDATE users SET is_vip = TRUE WHERE id = $1
    }
    w.WriteHeader(http.StatusOK)
}
```

> [!CAUTION]
> The Stripe webhook endpoint must NOT be behind the JWT auth middleware. It receives requests from Stripe's servers, not from authenticated users.

