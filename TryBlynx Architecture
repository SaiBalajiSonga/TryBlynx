### Stream C — Go WebSocket Engine

#### [NEW] [upgrader.go](file:///c:/Users/JOHNSON/Desktop/TryBlynx/internal/ws/upgrader.go)
**JWT-Secured WebSocket Handshake:**

```go
func ServeWS(hub *Hub, w http.ResponseWriter, r *http.Request) {
    // 1. Extract JWT from query param ?token=xxx OR Authorization header
    tokenStr := r.URL.Query().Get("token")
    if tokenStr == "" {
        tokenStr = strings.TrimPrefix(r.Header.Get("Authorization"), "Bearer ")
    }

    // 2. Validate JWT — REJECT if invalid
    claims, err := auth.ValidateToken(tokenStr)
    if err != nil {
        http.Error(w, "Unauthorized", http.StatusUnauthorized)
        return  // Connection refused — no upgrade
    }

    // 3. Upgrade only after successful auth
    conn, err := upgrader.Upgrade(w, r, nil)
    if err != nil { return }

    // 4. Create client with authenticated identity
    client := &Client{
        Hub:          hub,
        Conn:         conn,
        UserID:       claims.UserID,
        IsVIP:        claims.IsVIP,
        Shadowbanned: claims.Shadowbanned,
        Send:         make(chan []byte, 256),
    }
    hub.Register <- client
    go client.WritePump()
    go client.ReadPump()
}
```

