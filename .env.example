# ═══════════════════════════════════════════════
# TryBlynx — Environment Configuration
# Copy this file to .env and fill in real values
# ═══════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────
POSTGRES_USER=tryblynx
POSTGRES_PASSWORD=tryblynx
POSTGRES_DB=tryblynx

# Full DSN (used by the Go app inside Docker network)
DATABASE_URL=postgres://tryblynx:tryblynx@postgres:5432/tryblynx?sslmode=disable

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ───────────────────────────────────────
# HMAC-SHA256 signing key. MUST be changed in production.
# Generate with: openssl rand -hex 32
JWT_SECRET=ecd34b5dd5434ca8ace5f19fadc37f5a3b7d7e5a68d44cd204627bb019efb316
# ── Stripe ────────────────────────────────────
# Test-mode keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
# Webhook signing secret from Stripe Dashboard or `stripe listen`
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── Coturn (TURN/STUN) ───────────────────────
COTURN_SECRET=coturn-static-auth-secret

# ── Server ────────────────────────────────────
SERVER_PORT=8080

# ── Database Pool (Go pgxpool) ────────────────
# These bound the PG connection pool, NOT tied 1:1 to WS connections.
DB_MAX_CONNS=100
DB_MIN_CONNS=10
